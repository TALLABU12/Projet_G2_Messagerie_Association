<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="359.0" prefWidth="540.0" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.MainController">

    <Label fx:id="outputLabel" text="Nom Utilisateur:">
      <font>
         <Font size="18.0" />
      </font></Label>
    <TextField fx:id="inputField">
      <VBox.margin>
         <Insets left="30.0" right="30.0" />
      </VBox.margin></TextField>
   <Label fx:id="outputLabel1" text="Mot de passe:">
      <font>
         <Font size="18.0" />
      </font>
   </Label>
   <PasswordField>
      <opaqueInsets>
         <Insets />
      </opaqueInsets>
      <VBox.margin>
         <Insets left="30.0" right="30.0" />
      </VBox.margin>
   </PasswordField>
   <Label fx:id="outputLabel11" text="Confirmer Mot de passe:">
      <font>
         <Font size="18.0" />
      </font>
   </Label>
   <PasswordField>
      <opaqueInsets>
         <Insets />
      </opaqueInsets>
      <VBox.margin>
         <Insets left="30.0" right="30.0" />
      </VBox.margin>
   </PasswordField>
   <HBox prefHeight="32.0" prefWidth="468.0">
      <children>
         <Label fx:id="outputLabel111" text="Role:">
            <font>
               <Font size="18.0" />
            </font>
            <HBox.margin>
               <Insets left="90.0" right="30.0" />
            </HBox.margin>
         </Label>
         <ComboBox prefWidth="150.0" />
      </children>
      <padding>
         <Insets left="30.0" />
      </padding>
   </HBox>
   <HBox prefHeight="58.0" prefWidth="540.0">
      <children>
         <Button onAction="#onButtonClicked" text="Annuler">
            <HBox.margin>
               <Insets left="80.0" right="30.0" />
            </HBox.margin>
         </Button>
         <Button alignment="CENTER" onAction="#onButtonClicked" text="Reinitialiser">
            <HBox.margin>
               <Insets left="30.0" right="30.0" />
            </HBox.margin>
         </Button>
          <Button onAction="#onButtonClicked" text="S'inscrire">
            <HBox.margin>
               <Insets left="30.0" right="30.0" />
            </HBox.margin>
         </Button>
      </children>
      <padding>
         <Insets left="30.0" right="30.0" top="20.0" />
      </padding>
   </HBox>

</VBox>

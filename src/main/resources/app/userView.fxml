<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    UserController: org.example.ui.controllers.UserController
    Displayed when the "Utilisateurs" button is clicked in HomeView.
    Shows all users with their role badge and online/offline status.
-->
<BorderPane
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.ui.controllers.UserController"
    prefHeight="520.0"
    prefWidth="520.0"
    style="-fx-background-color: #1e1e2e;">

    <!-- ── Top bar ── -->
    <top>
        <VBox style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 0 0 1 0;">
            <padding><Insets top="20.0" bottom="16.0" left="24.0" right="24.0"/></padding>

            <!-- Title row -->
            <HBox alignment="CENTER_LEFT" spacing="10.0">
                <Label
                    text="Utilisateurs"
                    style="-fx-text-fill: #cdd6f4; -fx-font-size: 18; -fx-font-weight: bold;">
                    <font><Font name="System Bold" size="18.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Live counter badge -->
                <Label
                    fx:id="onlineCountLabel"
                    text="0 en ligne"
                    style="-fx-text-fill: #a6e3a1; -fx-font-size: 11; -fx-font-weight: bold;
                           -fx-background-color: #313244; -fx-background-radius: 10;
                           -fx-padding: 3 10 3 10;"/>
            </HBox>

            <!-- Subtitle -->
            <Label
                fx:id="totalCountLabel"
                text="0 membre(s) au total"
                style="-fx-text-fill: #a6adc8; -fx-font-size: 12;">
                <VBox.margin><Insets top="4.0"/></VBox.margin>
            </Label>
        </VBox>
    </top>

    <!-- ── Center: column headers + list ── -->
    <center>
        <VBox style="-fx-background-color: #1e1e2e;">
            <padding><Insets top="12.0" bottom="0.0" left="16.0" right="16.0"/></padding>

            <!-- Column headers -->
            <HBox
                fx:id="columnHeader"
                spacing="0.0"
                style="-fx-border-color: #45475a; -fx-border-width: 0 0 1 0; -fx-padding: 0 4 8 4;">

                <!-- Spacer matching the avatar width -->
                <Region prefWidth="46.0" minWidth="46.0"/>

                <Label
                    text="UTILISATEUR"
                    HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-text-fill: #585b70; -fx-font-size: 10; -fx-font-weight: bold;"/>

                <Label
                    text="ROLE"
                    prefWidth="120.0"
                    style="-fx-text-fill: #585b70; -fx-font-size: 10; -fx-font-weight: bold;"/>

                <Label
                    text="STATUT"
                    prefWidth="90.0"
                    style="-fx-text-fill: #585b70; -fx-font-size: 10; -fx-font-weight: bold;"/>
            </HBox>

            <!-- The list — cells are built entirely by UserController's cell factory -->
            <ListView
                fx:id="userListView"
                VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent; -fx-border-color: transparent;
                       -fx-padding: 6 0 0 0;"/>
        </VBox>
    </center>

    <!-- ── Bottom bar: Actualiser + Retour ── -->
    <bottom>
        <HBox
            alignment="CENTER_RIGHT"
            spacing="10.0"
            style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 1 0 0 0;">
            <padding><Insets top="12.0" bottom="12.0" left="16.0" right="16.0"/></padding>

            <Label
                fx:id="lastRefreshLabel"
                text=""
                HBox.hgrow="ALWAYS"
                style="-fx-text-fill: #585b70; -fx-font-size: 11;"/>

            <Button
                fx:id="reloadBtn"
                text="↻  Actualiser"
                onAction="#handleReload"
                style="-fx-background-color: #313244; -fx-text-fill: #89b4fa;
                       -fx-font-weight: bold; -fx-font-size: 12;
                       -fx-background-radius: 7; -fx-cursor: hand;
                       -fx-padding: 8 18 8 18;"/>

            <Button
                fx:id="backBtn"
                text="← Retour"
                onAction="#handleBack"
                style="-fx-background-color: #313244; -fx-text-fill: #a6adc8;
                       -fx-font-weight: bold; -fx-font-size: 12;
                       -fx-background-radius: 7; -fx-cursor: hand;
                       -fx-padding: 8 18 8 18;"/>
        </HBox>
    </bottom>

</BorderPane>

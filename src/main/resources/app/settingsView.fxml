<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="274.0" prefWidth="468.0" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.MainController">
   <HBox prefHeight="305.0" prefWidth="468.0">
      <children>
         <VBox alignment="CENTER_LEFT" prefHeight="274.0" prefWidth="312.0">
            <children>
            
                <Label fx:id="outputLabel" text="ID Utilisateur:">
                  <font>
                     <Font size="18.0" />
                  </font>
               </Label>
                <TextField fx:id="inputField" disable="true" editable="false">
                  <VBox.margin>
                     <Insets />
                  </VBox.margin>
               </TextField>
               <Label fx:id="outputLabel1" text="Nom Utilisateur:">
                  <font>
                     <Font size="18.0" />
                  </font>
               </Label>
               <TextField fx:id="inputField1" disable="true" editable="false">
                  <VBox.margin>
                     <Insets />
                  </VBox.margin>
               </TextField>
               <Label fx:id="outputLabel11" text="Role:">
                  <font>
                     <Font size="18.0" />
                  </font>
               </Label>
               <TextField fx:id="inputField11" disable="true" editable="false" />
               <Button onAction="#onButtonClicked" text="Annuler">
                  <VBox.margin>
                     <Insets top="20.0" />
                  </VBox.margin>
               </Button>
            </children>
            <padding>
               <Insets bottom="30.0" left="50.0" right="30.0" top="30.0" />
            </padding>
         </VBox>
         <VBox alignment="CENTER" prefHeight="274.0" prefWidth="210.0">
            <children>
                <Button onAction="#onButtonClicked" text="Changer Mot de passe">
                  <VBox.margin>
                     <Insets bottom="10.0" top="10.0" />
                  </VBox.margin>
               </Button>
               <Button onAction="#onButtonClicked" text="Se déconnecter">
                  <VBox.margin>
                     <Insets bottom="10.0" top="10.0" />
                  </VBox.margin>
               </Button>
               <Button onAction="#onButtonClicked" text="Supprimer compte">
                  <VBox.margin>
                     <Insets bottom="10.0" top="10.0" />
                  </VBox.margin>
               </Button>
            </children>
            <padding>
               <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
            </padding>
         </VBox>
      </children>
   </HBox>

</VBox>

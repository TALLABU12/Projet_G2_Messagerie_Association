<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
    LoginController: org.example.ui.controllers.LoginController
    Theme: Catppuccin Mocha – matches homeView.fxml
-->

<VBox alignment="CENTER" prefHeight="380.0" prefWidth="400.0" spacing="0" style="-fx-background-color: #1e1e2e;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ui.controllers.LoginController">

    <!-- ── Card container ── -->
    <VBox alignment="CENTER" spacing="14" style="-fx-background-color: #181825;                 -fx-background-radius: 12;                 -fx-border-color: #313244;                 -fx-border-radius: 12;                 -fx-border-width: 1;">
        <padding><Insets bottom="36" left="40" right="40" top="36" /></padding>

        <!-- App title -->
        <Label style="-fx-text-fill: #cdd6f4; -fx-font-weight: bold; -fx-font-size: 22;" text="Messagerie Association">
            <font><Font name="System Bold" size="22.0" /></font>
            <VBox.margin><Insets bottom="4" /></VBox.margin>
        </Label>

        <!-- Subtitle -->
        <Label style="-fx-text-fill: #a6adc8; -fx-font-size: 12;" text="Connectez-vous à votre compte">
            <VBox.margin><Insets bottom="16" /></VBox.margin>
        </Label>

        <!-- Username label -->
        <Label maxWidth="Infinity" style="-fx-text-fill: #a6adc8; -fx-font-size: 11; -fx-font-weight: bold;" text="Nom d'utilisateur" />

        <!-- Username field -->
        <TextField fx:id="nameField" maxWidth="Infinity" promptText="Entrez votre nom d'utilisateur" style="-fx-background-color: #313244;                    -fx-text-fill: #cdd6f4;                    -fx-prompt-text-fill: #585b70;                    -fx-background-radius: 8;                    -fx-border-color: #45475a;                    -fx-border-radius: 8;                    -fx-border-width: 1;                    -fx-padding: 9 12 9 12;                    -fx-font-size: 13;">
            <VBox.margin><Insets bottom="8" /></VBox.margin>
        </TextField>

        <!-- Password label -->
        <Label maxWidth="Infinity" style="-fx-text-fill: #a6adc8; -fx-font-size: 11; -fx-font-weight: bold;" text="Mot de passe" />

        <!-- Password field -->
        <PasswordField fx:id="passwordField" maxWidth="Infinity" promptText="Entrez votre mot de passe" style="-fx-background-color: #313244;                    -fx-text-fill: #cdd6f4;                    -fx-prompt-text-fill: #585b70;                    -fx-background-radius: 8;                    -fx-border-color: #45475a;                    -fx-border-radius: 8;                    -fx-border-width: 1;                    -fx-padding: 9 12 9 12;                    -fx-font-size: 13;">
            <VBox.margin><Insets bottom="20" /></VBox.margin>
        </PasswordField>

        <!-- Login button -->
        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLoginButton" style="-fx-background-color: #89b4fa;                    -fx-text-fill: #1e1e2e;                    -fx-font-weight: bold;                    -fx-font-size: 13;                    -fx-background-radius: 8;                    -fx-cursor: hand;                    -fx-padding: 10 0 10 0;" text="Se connecter" />

        <!-- Status / error label (hidden by default) -->
        <Label fx:id="statusLabel" alignment="CENTER" maxWidth="Infinity" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" text="" wrapText="true">
            <VBox.margin><Insets top="6" /></VBox.margin>
        </Label>

    </VBox>

    <VBox.margin><Insets left="32" right="32" /></VBox.margin>
</VBox>

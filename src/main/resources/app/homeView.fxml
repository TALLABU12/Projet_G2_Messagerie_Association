<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox
    fx:id="rootHBox"
    xmlns="http://javafx.com/javafx/21"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="org.example.ui.controllers.HomeController"
    prefHeight="600.0"
    prefWidth="900.0"
    style="-fx-background-color: #1e1e2e;">

    <!-- ═══════════════════════════════════════════════════
         LEFT SIDEBAR
         ═══════════════════════════════════════════════════ -->
    <VBox
        fx:id="sidebarVBox"
        alignment="TOP_CENTER"
        prefWidth="130.0"
        minWidth="110.0"
        style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 0 1 0 0;">
        <padding><Insets top="20.0" bottom="20.0" left="10.0" right="10.0"/></padding>

        <Label
            fx:id="currentUserLabel"
            text="Messagerie"
            maxWidth="Infinity"
            alignment="CENTER"
            style="-fx-text-fill: #cdd6f4; -fx-font-weight: bold;">
            <font><Font name="System Bold" size="14.0"/></font>
            <VBox.margin><Insets bottom="20.0"/></VBox.margin>
        </Label>

        <Separator style="-fx-background-color: #313244;">
            <VBox.margin><Insets bottom="15.0"/></VBox.margin>
        </Separator>

        <!-- Always visible — shows all users or ORGANISATEUR panel depending on role -->
        <Button
            fx:id="usersBtn"
            text="Utilisateurs"
            onAction="#handleUsersBtn"
            maxWidth="Infinity"
            style="-fx-background-color: #313244; -fx-text-fill: #cdd6f4; -fx-background-radius: 6; -fx-cursor: hand;">
            <VBox.margin><Insets bottom="8.0"/></VBox.margin>
        </Button>

        <Region VBox.vgrow="ALWAYS"/>

        <Button
            fx:id="quitBtn"
            text="Quitter"
            onAction="#handleQuit"
            maxWidth="Infinity"
            style="-fx-background-color: #f38ba8; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </VBox>

    <!-- ═══════════════════════════════════════════════════
         CONVERSATION LIST PANEL
         ═══════════════════════════════════════════════════ -->
    <VBox
        fx:id="conversationPanel"
        prefWidth="220.0"
        minWidth="180.0"
        style="-fx-background-color: #1e1e2e; -fx-border-color: #313244; -fx-border-width: 0 1 0 0;">
        <padding><Insets top="12.0" bottom="12.0" left="8.0" right="8.0"/></padding>

        <Label
            text="Conversations"
            maxWidth="Infinity"
            alignment="CENTER_LEFT"
            style="-fx-text-fill: #a6adc8; -fx-font-size: 11; -fx-font-weight: bold;">
            <VBox.margin><Insets bottom="8.0"/></VBox.margin>
        </Label>

        <Button
            fx:id="addConversationBtn"
            text="+ Ajouter Conversation"
            onAction="#handleAddConversation"
            maxWidth="Infinity"
            style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e; -fx-font-weight: bold; -fx-background-radius: 6; -fx-cursor: hand;">
            <VBox.margin><Insets bottom="10.0"/></VBox.margin>
        </Button>

        <ListView
            fx:id="conversationListView"
            VBox.vgrow="ALWAYS"
            style="-fx-background-color: transparent; -fx-border-color: #313244; -fx-border-radius: 6; -fx-background-radius: 6;"/>
    </VBox>

    <!-- ═══════════════════════════════════════════════════
         CHAT PANEL
         ═══════════════════════════════════════════════════ -->
    <BorderPane
        fx:id="chatPanel"
        HBox.hgrow="ALWAYS"
        disable="true"
        style="-fx-background-color: #1e1e2e; -fx-opacity: 0.45;">

        <!-- TOP: recipient name + role badge -->
        <top>
            <HBox
                alignment="CENTER_LEFT"
                spacing="10.0"
                prefHeight="52.0"
                style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 0 0 1 0;">
                <padding><Insets left="18.0" right="18.0"/></padding>

                <Label
                    fx:id="destinataireNameLabel"
                    text="Sélectionnez une conversation"
                    style="-fx-text-fill: #cdd6f4; -fx-font-size: 15; -fx-font-weight: bold;">
                    <font><Font name="System Bold" size="15.0"/></font>
                </Label>

                <!-- Role badge — text set by controller, hidden until a convo is selected -->
                <Label
                    fx:id="destinataireRoleLabel"
                    text=""
                    style="-fx-text-fill: #cba6f7; -fx-font-size: 11; -fx-font-weight: bold;
                           -fx-background-color: #313244; -fx-background-radius: 5;
                           -fx-padding: 2 8 2 8;">
                </Label>
            </HBox>
        </top>

        <!-- CENTER: chat bubbles -->
        <center>
            <ListView
                fx:id="chatListView"
                style="-fx-background-color: #1e1e2e; -fx-border-color: transparent;"
                BorderPane.alignment="CENTER"/>
        </center>

        <!-- BOTTOM: input bar -->
        <bottom>
            <HBox
                alignment="CENTER_LEFT"
                prefHeight="55.0"
                spacing="8.0"
                style="-fx-background-color: #181825; -fx-border-color: #313244; -fx-border-width: 1 0 0 0;">
                <padding><Insets top="8.0" bottom="8.0" left="12.0" right="12.0"/></padding>

                <!--
                    -fx-text-fill: #cdd6f4  → typed text bright white
                    -fx-control-inner-background drives the actual glyph color in most FX skins;
                    setting it here + text-fill covers both the Modena and Caspian skins.
                -->
                <TextArea
                    fx:id="messageTextArea"
                    promptText="Écrire un message…"
                    prefHeight="38.0"
                    maxHeight="38.0"
                    wrapText="true"
                    HBox.hgrow="ALWAYS"
                    style="-fx-control-inner-background: #313244;
                           -fx-background-color: #313244;
                           -fx-text-fill: #cdd6f4;
                           -fx-prompt-text-fill: #585b70;
                           -fx-highlight-fill: #89b4fa;
                           -fx-highlight-text-fill: #1e1e2e;
                           -fx-background-radius: 8;
                           -fx-border-radius: 8;
                           -fx-border-color: transparent;
                           -fx-font-size: 13;"/>

                <Button
                    fx:id="sendBtn"
                    text="Envoyer"
                    onAction="#handleSend"
                    style="-fx-background-color: #89b4fa; -fx-text-fill: #1e1e2e;
                           -fx-font-weight: bold; -fx-background-radius: 8;
                           -fx-cursor: hand; -fx-pref-height: 38; -fx-pref-width: 85;"/>
            </HBox>
        </bottom>
    </BorderPane>

</HBox>

<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="274.0" prefWidth="468.0" spacing="10" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.MainController">

    <Label fx:id="outputLabel" text="Nom Utilisateur:">
      <font>
         <Font size="18.0" />
      </font></Label>
    <TextField fx:id="inputField">
      <VBox.margin>
         <Insets left="30.0" right="30.0" />
      </VBox.margin></TextField>
   <Label fx:id="outputLabel1" text="Mot de passe:">
      <font>
         <Font size="18.0" />
      </font>
   </Label>
   <PasswordField>
      <opaqueInsets>
         <Insets />
      </opaqueInsets>
      <VBox.margin>
         <Insets left="30.0" right="30.0" />
      </VBox.margin>
   </PasswordField>
    <Button onAction="#onButtonClicked" text="Se connecter" />
   <Button onAction="#onButtonClicked" text="S'inscrire" />

</VBox>
